# Basira — environment template
# Copy to .env and fill in the real values.

# ===== AI keys (required for analysis) =====
# Get from https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-...

# Get from https://www.voyageai.com/
VOYAGE_API_KEY=pa-...

# ===== Server =====
BASIRA_HOST=127.0.0.1
BASIRA_PORT=8000
BASIRA_LOG_LEVEL=INFO

# ===== Storage =====
# Paths are resolved relative to the project root.
BASIRA_DB_PATH=data/basira.db
BASIRA_DATA_DIR=data
BASIRA_DOCUMENTS_DIR=data/documents

# ===== Source registry =====
BASIRA_SOURCES_CSV=data/context_engine_sources_master.csv
BASIRA_SOURCES_OVERRIDES=data/sources_overrides.yaml

# ===== Analysis policy =====
# Comma-separated list of tiers to analyze with Claude.
# Tier 1 + 2 recommended for v1 (keeps cost near ~$70/month).
# Add "Tier 3" to analyze everything.
BASIRA_ANALYZE_TIERS=Tier 1,Tier 2

# Claude model to use for analysis.
BASIRA_CLAUDE_MODEL=claude-sonnet-4-5-20250929

# Max body tokens passed to Claude (truncates if longer).
BASIRA_MAX_BODY_TOKENS=30000

# Voyage embedding model.
BASIRA_VOYAGE_MODEL=voyage-3

# ===== Admin auth =====
# Random token required for /admin/* endpoints.
# Generate one with: python -c "import secrets; print(secrets.token_urlsafe(32))"
BASIRA_ADMIN_TOKEN=changeme-generate-a-real-one

# ===== CORS =====
# Comma-separated list of allowed origins. Use * for local dev.
BASIRA_CORS_ORIGINS=*

# ===== Scheduler =====
# Set to 0 to disable background jobs (useful for tests and one-shot scripts).
BASIRA_SCHEDULER_ENABLED=1
